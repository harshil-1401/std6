          "description": "Heading shown above the scene",
          "default": "Classroom Materials Hunt"
        },
        "objects": {
          "type": "array",
          "description": "List of classroom objects to tag",
          "item_schema": {
            "id": "string — unique identifier",
            "label": "string — display name",
            "correctMaterial": "string — must match one of the material ids",
            "hint": "string — one-line clue shown on wrong answer",
            "x": "number — horizontal position in scene (0–100 percent)",
            "y": "number — vertical position in scene (0–100 percent)",
            "emoji": "string — emoji icon for the object",
            "color": "string — hex colour for the object chip"
          }
        },
        "materials": {
          "type": "array",
          "description": "Palette of 6 material choices",
          "item_schema": {
            "id": "string — unique key (matches correctMaterial in objects)",
