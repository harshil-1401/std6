                }
              }
            }
          }
        }
      }
    ],
  
    "designTokens": {
      "_source": "Singularity_tool_Design_1.pdf",
      "font": "Poppins",
      "colors": {
        "primaryBlue":  "#4A4DC9",
        "primaryOrange":"#FF7212",
        "gradStart":    "#533086",
        "gradEnd":      "#FC9145",
        "dark":         "#4E4E4E",
        "mid":          "#CACACA",
        "light":        "#EBEBEB",
        "lightest":     "#F5F5F5",
        "accentPurple": "#C1C1EA",
        "accentPeach":  "#FFF3E4",
        "white":        "#FFFFFF"
      },
      "buttonStates": ["Enabled", "Disabled", "Hover", "Pressed"],
      "buttonVariants": ["Contained", "Outlined", "Texted"]
    },
  
    "decisionTree": {
      "_comment": "Logical decision tree used to identify materials; driven by the four property questions in order",
      "root": {
        "property": "hardness",
        "branches": {
          "hard": {
            "property": "solubility",
            "branches": {
              "soluble": {
                "property": "lustre",
                "branches": {
                  "lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Gold, Iron, Brass",
                      "light": "Possibly: Zinc, Aluminium"
                    }
                  },
                  "non-lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Stone salt",
                      "light": "Possibly: Common Salt, Glucose"
                    }
                  }
                }
              },
              "insoluble": {
                "property": "lustre",
                "branches": {
                  "lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Iron, Steel, Copper",
                      "light": "Possibly: Aluminium Foil"
                    }
                  },
                  "non-lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Stone, Brick",
                      "light": "Possibly: Wood, Chalk"
                    }
                  }
                }
              }
            }
          },
          "soft": {
            "property": "solubility",
            "branches": {
              "soluble": {
                "property": "lustre",
                "branches": {
                  "lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Tin (soft form)",
                      "light": "Possibly: Wax (light form)"
                    }
                  },
                  "non-lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Heavy sugar crystals",
                      "light": "Possibly: Sugar, Powdered salt"
                    }
                  }
                }
              },
              "insoluble": {
                "property": "lustre",
                "branches": {
                  "lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Lead sheet",
                      "light": "Possibly: Aluminium Foil (crumpled)"
                    }
                  },
                  "non-lustrous": {
                    "property": "mass",
                    "branches": {
                      "heavy": "Possibly: Clay, Mud",
                      "light": "Possibly: Rubber, Sponge, Cotton, Paper"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
  
    "agentReadme": {
      "quickReference": {
        "commonSalt":       { "hardness": "hard", "solubility": "soluble",   "lustre": "non-lustrous", "mass": "light"  },
        "iron":             { "hardness": "hard", "solubility": "insoluble",  "lustre": "lustrous",     "mass": "heavy"  },
        "sugar":            { "hardness": "soft", "solubility": "soluble",    "lustre": "non-lustrous", "mass": "light"  },
        "copper":           { "hardness": "hard", "solubility": "insoluble",  "lustre": "lustrous",     "mass": "heavy"  },
        "wood":             { "hardness": "hard", "solubility": "insoluble",  "lustre": "non-lustrous", "mass": "light"  },
        "chalk":            { "hardness": "soft", "solubility": "insoluble",  "lustre": "non-lustrous", "mass": "light"  },
        "aluminium":        { "hardness": "soft", "solubility": "insoluble",  "lustre": "lustrous",     "mass": "light"  },
        "rubber":           { "hardness": "soft", "solubility": "insoluble",  "lustre": "non-lustrous", "mass": "light"  },
        "gold":             { "hardness": "hard", "solubility": "insoluble",  "lustre": "lustrous",     "mass": "heavy"  },
        "steel":            { "hardness": "hard", "solubility": "insoluble",  "lustre": "lustrous",     "mass": "heavy"  }
      },
      "tips": [
        "Always supply BOTH materialX and materialY to avoid fallback defaults.",
        "The four property keys (hardness, solubility, lustre, mass) are REQUIRED inside properties.",
        "Use descriptive description strings — they appear on the reveal panel.",
        "Emoji pairs that are visually distinct improve student engagement.",
        "For simple demos, leave additionalProps empty — defaults to Salt vs Iron Nail."
      ]
    }
  }